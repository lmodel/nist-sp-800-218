@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://w3id.org/lmodel/nist-sp-800-218.owl.ttl> a owl:Ontology ;
    rdfs:label "nist-sp-800-218" ;
    dcterms:license "Apache-2.0" ;
    dcterms:source <https://doi.org/10.6028/NIST.SP.800-218> ;
    dcterms:title "nist-sp-800-218" ;
    pav:version "1.1.0" ;
    rdfs:seeAlso <https://lmodel.github.io/nist-sp-800-218> ;
    skos:definition "'Electronic (LinkML) Version of Secure Software Development Framework (SSDF): Recommendations for Mitigating the Risk of Software Vulnerabilities'" .

nist_sp_800_218:SSFDDocument a owl:Class ;
    rdfs:label "SSFDDocument" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_218:catalog ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nist_sp_800_218:catalog ],
        [ a owl:Restriction ;
            owl:allValuesFrom nist_sp_800_218:CatalogBody ;
            owl:onProperty nist_sp_800_218:catalog ] ;
    skos:definition "Root wrapper for SSDF catalog content" ;
    skos:exactMatch linkml:Any ;
    skos:inScheme <https://w3id.org/lmodel/nist-sp-800-218> .

nist_sp_800_218:CatalogElement a owl:Class ;
    rdfs:label "CatalogElement" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom nist_sp_800_218:Link ;
            owl:onProperty nist_sp_800_218:links ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nist_sp_800_218:id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_218:parts ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_218:id ],
        [ a owl:Restriction ;
            owl:allValuesFrom nist_sp_800_218:Property ;
            owl:onProperty nist_sp_800_218:props ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_218:links ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_218:props ],
        [ a owl:Restriction ;
            owl:allValuesFrom nist_sp_800_218:Part ;
            owl:onProperty nist_sp_800_218:parts ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nist_sp_800_218:id ] ;
    skos:definition "Base class for identifiable catalog elements" ;
    skos:inScheme <https://w3id.org/lmodel/nist-sp-800-218> .

nist_sp_800_218:Task a owl:Class ;
    rdfs:label "Task" ;
    rdfs:subClassOf nist_sp_800_218:IdentifiedElement ;
    skos:definition "An SSDF task within a practice" ;
    skos:inScheme <https://w3id.org/lmodel/nist-sp-800-218> .

nist_sp_800_218:Address a owl:Class ;
