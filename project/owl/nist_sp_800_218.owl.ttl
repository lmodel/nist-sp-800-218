nist_sp_800_218:Link a owl:Class ;
    rdfs:label "Link" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_218:text ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_218:rel ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_218:href ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nist_sp_800_218:href ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nist_sp_800_218:text ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nist_sp_800_218:text ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nist_sp_800_218:href ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nist_sp_800_218:rel ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nist_sp_800_218:rel ] ;
    skos:definition "Relationship link with optional annotation text" ;
    skos:inScheme <https://w3id.org/lmodel/nist-sp-800-218> .

nist_sp_800_218:Property a owl:Class ;
    rdfs:label "Property" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nist_sp_800_218:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nist_sp_800_218:ns ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_218:name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_218:value ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nist_sp_800_218:value ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_218:ns ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nist_sp_800_218:value ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nist_sp_800_218:ns ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nist_sp_800_218:name ] ;
    skos:definition "A name-value property with optional namespace" ;
    skos:inScheme <https://w3id.org/lmodel/nist-sp-800-218> .

