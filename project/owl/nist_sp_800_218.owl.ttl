            owl:onProperty nist_sp_800_218:uuid ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_218:back_matter ] ;
    skos:definition "Main SSDF catalog object" ;
    skos:exactMatch linkml:Any ;
    skos:inScheme <https://w3id.org/lmodel/nist-sp-800-218> .

<https://w3id.org/lmodel/nist-sp-800-218/CatalogElementClassValue#group> a owl:Class ;
    rdfs:label "group" ;
    rdfs:subClassOf nist_sp_800_218:CatalogElementClassValue ;
