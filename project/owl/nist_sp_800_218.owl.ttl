            owl:onProperty nist_sp_800_218:state ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nist_sp_800_218:state ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nist_sp_800_218:city ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_218:city ],
        [ a owl:Restriction ;
