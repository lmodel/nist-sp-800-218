nist_sp_800_218:CatalogElementClassValue a owl:Class ;
    rdfs:label "CatalogElementClassValue" ;
    owl:unionOf ( <https://w3id.org/lmodel/nist-sp-800-218/CatalogElementClassValue#group> <https://w3id.org/lmodel/nist-sp-800-218/CatalogElementClassValue#practice> <https://w3id.org/lmodel/nist-sp-800-218/CatalogElementClassValue#task> ) ;
    skos:definition "Allowed class values for SSDF catalog elements" ;
    skos:inScheme <https://w3id.org/lmodel/nist-sp-800-218> ;
    linkml:permissible_values <https://w3id.org/lmodel/nist-sp-800-218/CatalogElementClassValue#group>,
        <https://w3id.org/lmodel/nist-sp-800-218/CatalogElementClassValue#practice>,
        <https://w3id.org/lmodel/nist-sp-800-218/CatalogElementClassValue#task> .

nist_sp_800_218:IdentifiedElement a owl:Class ;
    rdfs:label "IdentifiedElement" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nist_sp_800_218:_class ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_218:title ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nist_sp_800_218:title ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_218:_class ],
        [ a owl:Restriction ;
            owl:allValuesFrom nist_sp_800_218:CatalogElementClassValue ;
            owl:onProperty nist_sp_800_218:_class ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nist_sp_800_218:title ],
        nist_sp_800_218:CatalogElement ;
    skos:definition "A catalog element with a title and class classification" ;
    skos:inScheme <https://w3id.org/lmodel/nist-sp-800-218> .

