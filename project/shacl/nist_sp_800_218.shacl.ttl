            sh:order 0 ;
            sh:path nist_sp_800_218:resources ],
        [ sh:class nist_sp_800_218:Property ;
            sh:description "List of properties" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path nist_sp_800_218:props ],
        [ sh:class linkml:Any ;
            sh:description "Postal addresses" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path nist_sp_800_218:addresses ],
        [ sh:class nist_sp_800_218:Link ;
            sh:description "List of links and relationships" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path nist_sp_800_218:links ],
        [ sh:datatype xsd:string ;
            sh:description "Name of a property or part" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path nist_sp_800_218:name ],
        [ sh:datatype xsd:string ;
            sh:description "State or region" ;
