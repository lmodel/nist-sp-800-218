nist_sp_800_218:Part a sh:NodeShape ;
    rdfs:comment "Structured narrative part containing prose content" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Human-readable title" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path nist_sp_800_218:title ],
        [ sh:datatype xsd:string ;
            sh:description "Unique identifier for an element" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path nist_sp_800_218:id ],
        [ sh:datatype xsd:string ;
            sh:description "Name of a property or part" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path nist_sp_800_218:name ],
        [ sh:class nist_sp_800_218:Part ;
            sh:description "Nested parts that provide prose and structure" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
