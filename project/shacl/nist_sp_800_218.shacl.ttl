@prefix linkml: <https://w3id.org/linkml/> .
@prefix nist_sp_800_218: <https://w3id.org/lmodel/nist-sp-800-218/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

nist_sp_800_218:CatalogElement a sh:NodeShape ;
    rdfs:comment "Base class for identifiable catalog elements" ;
    sh:closed false ;
    sh:ignoredProperties ( rdf:type nist_sp_800_218:controls nist_sp_800_218:name nist_sp_800_218:title nist_sp_800_218:_class nist_sp_800_218:prose ) ;
    sh:property [ sh:class nist_sp_800_218:Part ;
            sh:description "Nested parts that provide prose and structure" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path nist_sp_800_218:parts ],
        [ sh:datatype xsd:string ;
            sh:description "Unique identifier for an element" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path nist_sp_800_218:id ],
        [ sh:class nist_sp_800_218:Property ;
            sh:description "List of properties" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path nist_sp_800_218:props ],
        [ sh:class nist_sp_800_218:Link ;
            sh:description "List of links and relationships" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path nist_sp_800_218:links ] ;
    sh:targetClass nist_sp_800_218:CatalogElement .

nist_sp_800_218:IdentifiedElement a sh:NodeShape ;
    rdfs:comment "A catalog element with a title and class classification" ;
    sh:closed true ;
    sh:ignoredProperties ( nist_sp_800_218:controls nist_sp_800_218:name nist_sp_800_218:prose rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Unique identifier for an element" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path nist_sp_800_218:id ],
        [ sh:description "Classification of a catalog element" ;
            sh:in ( "group" "practice" "task" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path nist_sp_800_218:_class ],
        [ sh:class nist_sp_800_218:Part ;
            sh:description "Nested parts that provide prose and structure" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path nist_sp_800_218:parts ],
        [ sh:class nist_sp_800_218:Property ;
            sh:description "List of properties" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path nist_sp_800_218:props ],
        [ sh:class nist_sp_800_218:Link ;
            sh:description "List of links and relationships" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path nist_sp_800_218:links ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable title" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path nist_sp_800_218:title ] ;
    sh:targetClass nist_sp_800_218:IdentifiedElement .

nist_sp_800_218:Control a sh:NodeShape ;
