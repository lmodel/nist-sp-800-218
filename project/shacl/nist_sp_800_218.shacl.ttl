nist_sp_800_218:Link a sh:NodeShape ;
    rdfs:comment "Relationship link with optional annotation text" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Link or resource reference URI" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path nist_sp_800_218:href ],
        [ sh:datatype xsd:string ;
            sh:description "Relationship type for a link" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path nist_sp_800_218:rel ],
        [ sh:datatype xsd:string ;
            sh:description "Citation or link annotation text" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path nist_sp_800_218:text ] ;
    sh:targetClass nist_sp_800_218:Link .

nist_sp_800_218:Property a sh:NodeShape ;
    rdfs:comment "A name-value property with optional namespace" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Namespace URI for a property" ;
            sh:maxCount 1 ;
