            sh:order 2 ;
            sh:path nist_sp_800_218:ns ],
        [ sh:datatype xsd:string ;
            sh:description "Name of a property or part" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path nist_sp_800_218:name ],
        [ sh:datatype xsd:string ;
            sh:description "Property value" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path nist_sp_800_218:value ] ;
    sh:targetClass nist_sp_800_218:Property .

linkml:Any a sh:NodeShape ;
    rdfs:comment "Assignment of parties to a role",
        "Citation wrapper",
        "Main SSDF catalog object",
        "OSCAL back-matter section",
        "OSCAL metadata section for the SSDF catalog",
        "Party definition",
        "Postal address",
        "Reference link for a resource",
        "Referenced resource in back-matter",
        "Root wrapper for SSDF catalog content" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ),
        ( rdf:type ),
        ( rdf:type ),
        ( rdf:type ),
        ( rdf:type ),
        ( rdf:type ),
        ( rdf:type ),
        ( rdf:type ),
        ( rdf:type ),
        ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "UUID for catalog or resource element" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path nist_sp_800_218:uuid ],
        [ sh:class nist_sp_800_218:ControlGroup ;
            sh:description "List of SSDF practice groups in the catalog" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path nist_sp_800_218:groups ],
        [ sh:datatype xsd:string ;
            sh:description "UUID for catalog or resource element" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path nist_sp_800_218:uuid ],
        [ sh:class linkml:Any ;
            sh:description "Parties used in metadata" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path nist_sp_800_218:parties ],
        [ sh:datatype xsd:string ;
            sh:description "Last modification timestamp" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path nist_sp_800_218:last_modified ],
        [ sh:datatype xsd:string ;
            sh:description "Referenced party UUIDs" ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path nist_sp_800_218:party_uuids ],
        [ sh:class linkml:Any ;
            sh:description "Resource links" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path nist_sp_800_218:rlinks ],
        [ sh:datatype xsd:string ;
