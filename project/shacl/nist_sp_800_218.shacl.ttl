            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path nist_sp_800_218:href ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable title" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path nist_sp_800_218:title ],
        [ sh:datatype xsd:string ;
            sh:description "Party type" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path nist_sp_800_218:type ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable title" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path nist_sp_800_218:title ],
        [ sh:datatype xsd:string ;
