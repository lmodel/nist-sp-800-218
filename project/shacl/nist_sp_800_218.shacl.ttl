    sh:property [ sh:class nist_sp_800_218:Link ;
            sh:description "List of links and relationships" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path nist_sp_800_218:links ],
        [ sh:description "Classification of a catalog element" ;
            sh:in ( "group" "practice" "task" ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path nist_sp_800_218:_class ],
        [ sh:class nist_sp_800_218:Task ;
            sh:description "List of practices or tasks" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path nist_sp_800_218:controls ],
        [ sh:class nist_sp_800_218:Part ;
            sh:description "Nested parts that provide prose and structure" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path nist_sp_800_218:parts ],
        [ sh:datatype xsd:string ;
            sh:description "Unique identifier for an element" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path nist_sp_800_218:id ],
        [ sh:class nist_sp_800_218:Property ;
            sh:description "List of properties" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path nist_sp_800_218:props ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable title" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path nist_sp_800_218:title ] ;
    sh:targetClass nist_sp_800_218:Control .

