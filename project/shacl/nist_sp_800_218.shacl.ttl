            sh:order 1 ;
            sh:path nist_sp_800_218:city ],
        [ sh:datatype xsd:string ;
            sh:description "Citation or link annotation text" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path nist_sp_800_218:text ],
        [ sh:class linkml:Any ;
            sh:description "Root catalog payload" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path nist_sp_800_218:catalog ] ;
