            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path nist_sp_800_218:role_id ],
        [ sh:class nist_sp_800_218:Role ;
            sh:description "Roles used in metadata" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
